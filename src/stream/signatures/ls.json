{
    "command_name": "ls",
    "default_input_type": ".*",
    "default_output_type": ".*",
    "ignore_input": true,
    "args": [],
    "flags": [],
    "rules": [
        {
            "condition": {
                "flags": ["-l"]
            },
            "update": {
                "output_type": "(total [0-9]+)|([^ ]+ +[0-9]+ +[^ ]+ +[^ ]+ +[0-9]+ +[^ ]+ +[0-9]+ +[^ ]+ +.+)"
            }
        }
    ]
}