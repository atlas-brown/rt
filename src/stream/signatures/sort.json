{
    "command_name": "sort",
    "format": ["sort", "flag?"],
    "default_input_type": ".*",
    "default_output_type": ".*",
    "args": [],
    "flags": [
        {
            "name": "-n",
            "has_arg": false
        }
    ],
    "rules": [
        {
            "condition": {
                "flags": ["-n"]
            },
            "input_type": "-?[0-9]+",
            "output_type": "-?[0-9]+&{actual_input_type}"
        },
        {
            "condition": {
                "flags": []
            },
            "output_type": "{actual_input_type}"
        }
    ]
}