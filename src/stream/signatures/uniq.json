{
    "command_name": "uniq",
    "default_input_type": ".*",
    "default_output_type": ".*",
    "args": [],
    "flags": [],
    "rules": [
        {
            "condition": {
                "flags": ["-c"]
            },
            "update": {
                "output_type": "[0-9]+ {{actual_input_type}}"
            },
            "stop": true
        },
        {
            "condition": {},
            "update": {
                "output_type": "{{actual_input_type}}"
            }
        }
    ]
}