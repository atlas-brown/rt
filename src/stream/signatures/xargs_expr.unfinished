{
    "command_name": "xargs_expr",
    "format": ["xargs", "flag?", "expr", "arg+"],
    "default_input_type": "-?[0-9]+",
    "default_output_type": "-?[0-9]+",
    "args": [
        {
            "name": "expression",
            "type": ".+"
        }
    ],
    "flags": [
        {
            "name": "-n",
            "has_arg": true,
            "type": "\\d+"
        }
    ]
}
