{
    "command_name": "grep",
    "default_input_type": ".*",
    "default_output_type": ".*",
    "args": [
        {
            "name": "pattern",
            "type": ".+"
        },
        {
            "name": "file",
            "type": ".+"
        }
    ],
    "flags": [],
    "rules": [
        {
            "condition": {
                "args": ["file"]
            },
            "output_type": ".*{pattern}.*"
        },
        {
            "condition": {
                "flags": []
            },
            "output_type": ".*{pattern}.*&{actual_input_type}"
        }
    ]
}
