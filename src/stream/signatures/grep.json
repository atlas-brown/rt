{
    "command_name": "grep",
    "default_input_type": ".*",
    "default_output_type": ".*",
    "args": [
        {
            "name": "pattern",
            "type": ".+"
        },
        {
            "name": "file",
            "type": ".+"
        }
    ],
    "flags": [],
    "rules": [
        {
            "condition": {
                "no_flags": ["-o"]
            },
            "update": {
                "pattern": ".*{{pattern}}.*"
            }
        },
        {
            "condition": {
                "flags": ["-v"]
            },
            "update": {
                "pattern": "[^{{pattern}}]"
            }
        },
        {
            "condition": {
                "no_args": ["file"]
            },
            "update": {
                "pattern": "{{pattern}}&{{actual_input_type}}"
            }
        },
        {
            "condition": {},
            "update": {
                "output_type": "{{pattern}}"
            }
        }
    ]
}
