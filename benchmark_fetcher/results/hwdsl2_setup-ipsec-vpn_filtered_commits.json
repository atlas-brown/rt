{
    "hwdsl2/setup-ipsec-vpn": [
        {
            "message": "Cleanup",
            "commit_url": "https://github.com/hwdsl2/setup-ipsec-vpn/commit/79a344ec46ba2e7eb4e503a197c4bd4de4bb3203",
            "removed_lines": [
                "-    && ifconfig 2>/dev/null | grep \"$NET_IFACE\" | head -n 1 | grep -q \"mtu 1460\"; then"
            ],
            "added_lines": [
                "+    && ifconfig 2>/dev/null | grep \"$NET_IFACE\" | head -n 1 | grep -qi 'mtu 1460'; then"
            ]
        },
        {
            "message": "Cleanup\n\n- In rare cases, if a parent process traps SIGPIPE, the 'tr'\n  command in the VPN setup scripts could output an error\n  'tr: write error: Broken pipe'. This is a cosmetic error\n  that does NOT affect the functionality of the scripts. This\n  commit hides the error in such cases.",
            "commit_url": "https://github.com/hwdsl2/setup-ipsec-vpn/commit/a0409b439901668e478f3da0cd7ff0ff0daa5e9d",
            "removed_lines": [
                "-  p12_password=$(LC_CTYPE=C tr -dc 'A-HJ-NPR-Za-km-z2-9' < /dev/urandom | head -c 18)"
            ],
            "added_lines": [
                "+  p12_password=$(LC_CTYPE=C tr -dc 'A-HJ-NPR-Za-km-z2-9' </dev/urandom 2>/dev/null | head -c 18)"
            ]
        },
        {
            "message": "Update IKEv2 script\n\n- Add a variable VPN_DNS_NAME, which can be defined when running the\n  IKEv2 script in auto mode, to set up IKEv2 using a DNS name instead\n  of an IP address for the VPN server. The DNS name must be a fully\n  qualified domain name (FQDN). Example:\n  VPN_DNS_NAME=vpn.example.com bash ikev2.sh --auto\n- Minor cleanup",
            "commit_url": "https://github.com/hwdsl2/setup-ipsec-vpn/commit/c83148245bd833c770803cb483f6bda454871ba8",
            "removed_lines": [
                "-  server_addr=$(grep \"leftcert=\" /etc/ipsec.d/ikev2.conf | cut -f2 -d=)",
                "-  [ -z \"$server_addr\" ] && server_addr=$(grep \"leftcert=\" /etc/ipsec.conf | cut -f2 -d=)"
            ],
            "added_lines": [
                "+  server_addr=$(grep -s \"leftcert=\" /etc/ipsec.d/ikev2.conf | cut -f2 -d=)",
                "+  [ -z \"$server_addr\" ] && server_addr=$(grep -s \"leftcert=\" /etc/ipsec.conf | cut -f2 -d=)"
            ]
        },
        {
            "message": "Update IKEv2 script\n\n- Remove date/time suffix from client config file names",
            "commit_url": "https://github.com/hwdsl2/setup-ipsec-vpn/commit/5510e1f9d21c06e104f05730ba86eb0f6214291b",
            "removed_lines": [
                "-  p12_base64_oneline=$(base64 -w 52 \"$export_dir$client_name-$SYS_DT.p12\" | sed 's/$/\\\\n/' | tr -d '\\n')"
            ],
            "added_lines": [
                "+  p12_base64_oneline=$(base64 -w 52 \"$export_dir$client_name.p12\" | sed 's/$/\\\\n/' | tr -d '\\n')"
            ]
        },
        {
            "message": "Improve route detection\n\n- Limit Number of default routes returned to 1\n- Fixup for commit 323e7cf (#541)",
            "commit_url": "https://github.com/hwdsl2/setup-ipsec-vpn/commit/dfa607eef8f69db77510cc5d5ba8397535e1ff90",
            "removed_lines": [
                "-def_iface=$(route 2>/dev/null | grep '^default' | grep -o '[^ ]*$')"
            ],
            "added_lines": [
                "+def_iface=$(route 2>/dev/null | grep -m 1 '^default' | grep -o '[^ ]*$')"
            ]
        },
        {
            "message": "Limit Number of default routes returned to 1 (#541)",
            "commit_url": "https://github.com/hwdsl2/setup-ipsec-vpn/commit/323e7cfbf46ff977398463a8ad9018ad7576fe1d",
            "removed_lines": [
                "-def_iface=$(route 2>/dev/null | grep '^default' | grep -o '[^ ]*$')"
            ],
            "added_lines": [
                "+def_iface=$(route 2>/dev/null | grep -m 1 '^default' | grep -o '[^ ]*$')"
            ]
        },
        {
            "message": "Improve VPN config\n\n- Increase auto-generated IPsec PSK length to 20 characters\n- Add a note to README",
            "commit_url": "https://github.com/hwdsl2/setup-ipsec-vpn/commit/e8723245f02af0149c01932a854c0f0177f23394",
            "removed_lines": [
                "-  VPN_IPSEC_PSK=\"$(LC_CTYPE=C tr -dc 'A-HJ-NPR-Za-km-z2-9' < /dev/urandom | head -c 16)\""
            ],
            "added_lines": [
                "+  VPN_IPSEC_PSK=\"$(LC_CTYPE=C tr -dc 'A-HJ-NPR-Za-km-z2-9' < /dev/urandom | head -c 20)\""
            ]
        },
        {
            "message": "Improve network interfaces\n\n- Better detection of default network interface when the 'route'\n  command is not available",
            "commit_url": "https://github.com/hwdsl2/setup-ipsec-vpn/commit/5e3689198f089462765893389f6cf853ec53d97c",
            "removed_lines": [
                "-DEF_IFACE=\"$(route | grep '^default' | grep -o '[^ ]*$')\""
            ],
            "added_lines": [
                "+DEF_IFACE=\"$(route 2>/dev/null | grep '^default' | grep -o '[^ ]*$')\""
            ]
        },
        {
            "message": "Minor improvement to 'tr'",
            "commit_url": "https://github.com/hwdsl2/setup-ipsec-vpn/commit/83362607996da414546c0340d7abde2e0515544a",
            "removed_lines": [
                "-  VPN_IPSEC_PSK=\"$(< /dev/urandom tr -dc 'A-HJ-NPR-Za-km-z2-9' | head -c 16)\"",
                "-  VPN_PASSWORD=\"$(< /dev/urandom tr -dc 'A-HJ-NPR-Za-km-z2-9' | head -c 16)\""
            ],
            "added_lines": [
                "+  VPN_IPSEC_PSK=\"$(LC_CTYPE=C tr -dc 'A-HJ-NPR-Za-km-z2-9' < /dev/urandom | head -c 16)\"",
                "+  VPN_PASSWORD=\"$(LC_CTYPE=C tr -dc 'A-HJ-NPR-Za-km-z2-9' < /dev/urandom | head -c 16)\""
            ]
        }
    ]
}