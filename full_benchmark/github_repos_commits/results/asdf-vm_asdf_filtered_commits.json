                "-      echo \"$ext_cmds\" | grep \"  asdf $plugin\""
            ],
            "added_lines": [
                "+    echo \"$ext_cmds\" | cut -d'/' -f 1 | uniq | while read -r plugin; do",
                "+      echo \"$ext_cmds\" | grep \"$plugin/\" | sed \"s#^$plugin/#  asdf $plugin#\" | sort"
            ]
        },
