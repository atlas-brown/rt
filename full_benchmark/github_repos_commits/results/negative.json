    {
        "message": "fix(toolbox): avoid prompt injection",
        "commit_url": "https://github.com/ohmyzsh/ohmyzsh/commit/3b5f018f7025a347e4888408b566caeaef2fabd7",
        "removed_lines": [
            "-  [[ -f /run/.containerenv ]] && cat /run/.containerenv | awk -F\\\" '/name/ { print$2 }'"
        ],
        "added_lines": [
            "+  local _to_print=\"$(cat /run/.containerenv | awk -F\\\" '/name/ { print$2 }')\""
        ]
    },
    {
        "message": "fix(nvm): use `command cat` to avoid alias (#12410)",
        "commit_url": "https://github.com/ohmyzsh/ohmyzsh/commit/9af7ebcf36c20e1490a50fa5bab6319275859c17",
        "removed_lines": [
            "-      local nvmrc_node_version=$(nvm version $(cat \"$nvmrc_path\" | tr -dc '[:print:]'))"
        ],
        "added_lines": [
            "+      local nvmrc_node_version=$(nvm version $(command cat \"$nvmrc_path\" | tr -dc '[:print:]'))"
        ]
    },
    {
        "message": "fix(archlinux): make `upgrade` work with non-english\n\nCloses #12316",
        "commit_url": "https://github.com/ohmyzsh/ohmyzsh/commit/6d0362ef2f355a05cf945fae882ad1fa95428991",
        "removed_lines": [
            "-  local installedver=\"$(sudo pacman -Qi archlinux-keyring | grep -Po '(?<=Version         : ).*')\"",
            "-  local currentver=\"$(sudo pacman -Si archlinux-keyring | grep -Po '(?<=Version         : ).*')\""
        ],
        "added_lines": [
            "+  local installedver=\"$(LANG= sudo pacman -Qi archlinux-keyring | grep -Po '(?<=Version         : ).*')\"",
            "+  local currentver=\"$(LANG= sudo pacman -Si archlinux-keyring | grep -Po '(?<=Version         : ).*')\""
        ]
    },
    {
        "message": "fix: use `python3` for all `python` invocations (#10832)",
