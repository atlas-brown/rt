        "removed_lines": [
            "-     gradlew tasks --all | grep \"^[ ]*[a-zA-Z0-9:]*\\ -\\ \" | sed \"s/ - .*$//\" | sed \"s/[\\ ]*//\" > .gradletasknamecache"
        ],
        "added_lines": [
            "+     ./gradlew tasks --all | grep \"^[ ]*[a-zA-Z0-9:]*\\ -\\ \" | sed \"s/ - .*$//\" | sed \"s/[\\ ]*//\" > .gradletasknamecache"
        ]
