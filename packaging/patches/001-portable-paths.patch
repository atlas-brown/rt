diff --git a/src/stream/utils/paths.py b/src/stream/utils/paths.py
new file mode 100644
index 00000000..b955f8c4
--- /dev/null
+++ b/src/stream/utils/paths.py
@@ -0,0 +1,53 @@
+import os
+import sys
+from pathlib import Path
+
+# Packaging-time addition (see packaging/patches/001-portable-paths.patch).
+#
+# Upstream hardcodes "jars/automaton.jar" as a literal relative path, which
+# only resolves when RT is run with the repo root as the working directory
+# (true for rt.sh, uv run, and the Docker images, but not for a system-wide
+# `rt` installed by the .deb/.rpm package and invoked from an arbitrary
+# directory). This resolver adds install-aware fallbacks while keeping the
+# original CWD-relative behavior as the last resort, so nothing changes for
+# the existing dev/artifact-evaluation workflow.
+
+_JAR_NAMES = (
+    "automaton.jar",
+    "autorex.jar",
+    "slf4j-api-2.0.9.jar",
+    "slf4j-simple-2.0.9.jar",
+)
+
+
+def jars_dir() -> Path:
+    candidates = []
+
+    env_override = os.environ.get("RT_JARS_DIR")
+    if env_override:
+        candidates.append(Path(env_override))
+
+    # Where the .deb/.rpm build stages the jars, next to the venv (sys.prefix).
+    candidates.append(Path(sys.prefix) / "share" / "rt-artifact" / "jars")
+
+    # stream/utils/paths.py -> stream -> src -> repo root, for editable/dev checkouts.
+    repo_root = Path(__file__).resolve().parent.parent.parent.parent
+    candidates.append(repo_root / "jars")
+
+    # Original upstream assumption: CWD is the repo root.
+    candidates.append(Path("jars"))
+
+    for candidate in candidates:
+        if (candidate / "automaton.jar").is_file():
+            return candidate
+
+    searched = ", ".join(str(c) for c in candidates)
+    raise FileNotFoundError(
+        f"Could not locate RT's jars directory (tried: {searched}). "
+        "Set RT_JARS_DIR to override."
+    )
+
+
+def jar_classpath(*names: str) -> list[str]:
+    directory = jars_dir()
+    return [str(directory / name) for name in (names or _JAR_NAMES)]
